# Função para registrar leituras
 

def registrar_leitura():
    cursor.execute("SELECT id, nome FROM sensores")
    sensores = cursor.fetchall()
    if not sensores:
        print("Cadastre um sensor primeiro!")
        return
    print("Sensores disponíveis:")
    for s in sensores:
        print(f"{s[0]} - {s[1]}")
    sensor_id = int(input("Escolha o ID do sensor: "))
    temperatura = random.randint(50, 100)
    horario = datetime.now()
   
    # Inserir leitura no MySQL
    cursor.execute(
        "INSERT INTO leituras (sensor_id, temperatura, horario) VALUES (%s, %s, %s)",
        (sensor_id, temperatura, horario)
    )
    conexao.commit()
   
    # Criar alerta automático
    if temperatura <= 70:
        status = "NORMAL"
    elif temperatura <= 90:
        status = "ALERTA"
    else:
        status = "CRÍTICO"
   
    cursor.execute(
        "INSERT INTO alertas (leitura_id, status) VALUES (LAST_INSERT_ID(), %s)",
        (status,)
    )
    conexao.commit()
   
    print(f"Leitura registrada: {temperatura}°C - Status: {status}")
   
    # Salvar em JSON
    dados = {
        "sensor_id": sensor_id,
        "temperatura": temperatura,
        "horario": horario.strftime("%Y-%m-%d %H:%M:%S"),
        "status": status
    }
    with open("dados.json", "a") as f:
        json.dump(dados, f)
        f.write("\n")

